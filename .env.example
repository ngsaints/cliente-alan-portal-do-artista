# === Obrigatorio ===

# PostgreSQL Database
DATABASE_URL=postgresql://artista:sua_senha@localhost:5432/portal_do_artista

# Session Secret (gerar uma chave aleatoria longa)
SESSION_SECRET=change-this-to-a-long-random-secret-key

# API Port
PORT=3001

# Node Environment
NODE_ENV=production

# === Opcional - Cloudflare R2 Storage ===
# Se nao configurado, uploads vao para disco local (artifacts/api-server/uploads/)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=portal-do-artista
R2_PUBLIC_URL=

# === Opcional - Email (Resend) ===
# Para recuperacao de senha e notificacoes
RESEND_API_KEY=
EMAIL_FROM=noreply@portaldosartista.com.br

# === Opcional - MercadoPago ===
# Para pagamentos e assinaturas
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_URL=